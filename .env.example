# Copy this file to .env for local development.
# In Codex app, add the same keys in the MCP server form.

DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=readonly_user
DB_PASSWORD=replace_me

# Optional table names
DB_CUSTOMERS_TABLE=customers
DB_TICKETS_TABLE=tickets
